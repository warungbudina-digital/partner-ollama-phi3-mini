{
  "name": "partner-ollama-phi3-mini",
  "model": "phi3:mini",
  "role": "triage-router-extractor",
  "stabilityProfile": "google-cloud-shell-free",
  "promptFile": "prompts/SYSTEM.md",
  "docs": {
    "cloudShell": "docs/CLOUD_SHELL_PROFILE.md",
    "n8nRole": "docs/N8N_ROLE.md"
  },
  "runtime": {
    "ephemeralSessionSafe": true,
    "heavyDependenciesAllowed": false,
    "dockerPreferred": false,
    "localDatabasePreferred": false,
    "persistentArtifactsAllowed": "small-text-only",
    "targetRepoFootprintMb": 25,
    "maxSingleArtifactMb": 10,
    "tempWorkBudgetMb": 256
  },
  "n8n": {
    "mode": "tool-partner",
    "expectedInput": [
      "json",
      "text",
      "small-markdown"
    ],
    "expectedOutput": [
      "strict-json",
      "short-markdown",
      "plain-text"
    ],
    "escalateWhen": [
      "context too large",
      "task needs long reasoning",
      "task requires heavy codebase work",
      "task needs remote state not provided"
    ]
  },
  "taskFit": {
    "bestFor": [
      "classify intent / task",
      "extract fields into strict JSON",
      "route jobs in n8n",
      "write short summaries and labels",
      "cheap first-pass filtering"
    ],
    "avoid": [
      "long multi-file code generation",
      "heavy reasoning chains",
      "large context drafting",
      "deep architecture decisions"
    ]
  }
}
